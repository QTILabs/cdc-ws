# CDC Daemon
# Source settings
RW_HOST=localhost
RW_PORT=4566
RW_USER=root
RW_DBNAME=dev

# Sink settings
OS_URL=https://localhost:9200
OS_USER=admin
OS_PASSWORD=change-me
QDRANT_URL=https://localhost:6334
QDRANT_API_KEY=

# Pipeline configuration file
PIPELINES_FILE=pipelines.yaml

# Telemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Runtime labels
CONSUMER_ID=cdc-worker-1
HOSTNAME=cdc-worker-1

# Dead-letter queue
LOCAL_DLQ_DIR=/var/log/cdc-dlq

# CDC BFF / OpenID / Auth
CDC_DAEMON_GRPC_URL=http://localhost:50051
JWT_SECRET=change-me-too
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URL=http://localhost:8080/api/auth/oauth2/github/callback
