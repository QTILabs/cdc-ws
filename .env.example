# =============================================================================
# CDC Workspace — Environment Configuration
# Copy ke .env dan isi sesuai environment kamu
# cp .env.example .env
# =============================================================================

# ── RisingWave / Source Database ──────────────────────────────────────────────
# Database yang jadi sumber data (subscription CDC)
RW_HOST=localhost
RW_PORT=4566
RW_USER=root
RW_DBNAME=dev
RW_SSLMODE=disable

# ── OpenSearch / Sink ────────────────────────────────────────────────────────
# Destination — OpenSearch untuk indexing & search
OS_URL=https://localhost:9200
OS_USER=admin
OS_PASSWORD=your_opensearch_password

# ── Pipeline ─────────────────────────────────────────────────────────────────
# File definisi pipeline (YAML atau TOML)
PIPELINES_FILE=pipelines.yaml

# ── Backfill ─────────────────────────────────────────────────────────────────
# Sink data existing dari MV ke OpenSearch (bukan cuma perubahan baru)
# true = aktifkan, false = hanya data baru (default)
BACKFILL_ENABLED=false

# ── Telemetry / Observability ────────────────────────────────────────────────
# OpenTelemetry Collector (SigNoz / Jaeger / dll)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=cdc-daemon

# ── Runtime Labels ───────────────────────────────────────────────────────────
# Identifier untuk consumer & host
CONSUMER_ID=cdc-local
HOSTNAME=cdc-local

# ── Dead Letter Queue ─────────────────────────────────────────────────────────
# Directory untuk record yang gagal di-sink
LOCAL_DLQ_DIR=/var/log/cdc-dlq

# ── gRPC Daemon URL (untuk BFF) ───────────────────────────────────────────────
# Alamat daemon — dari sisi BFF
CDC_DAEMON_GRPC_URL=http://localhost:50051

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Secret untuk signing JWT token (HARUS diubah di production!)
JWT_SECRET=change-me-too

# ── Health Check ──────────────────────────────────────────────────────────────
# Port untuk /healthz endpoint
HEALTH_PORT=9090

# ── OAuth2 / GitHub (opsional) ───────────────────────────────────────────────
# Kalau mau login via GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URL=http://localhost:8080/api/auth/oauth2/github/callback

# ── Keycloak OIDC (opsional) ──────────────────────────────────────────────────
# Kalau mau login via Keycloak
KEYCLOAK_CLIENT_ID=cdc-bff
KEYCLOAK_CLIENT_SECRET=your_keycloak_secret
KEYCLOAK_ISSUER=http://localhost:8081/realms/cdc
KEYCLOAK_REDIRECT_URL=http://localhost:8080/api/auth/oauth2/keycloak/callback
